# Copy this to .env and fill in your real values
# Or set these as environment variables on Railway

# Gmail Account 1
GMAIL_1_EMAIL=your.email@gmail.com
GMAIL_1_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Gmail Account 2 (optional)
GMAIL_2_EMAIL=your.email2@gmail.com
GMAIL_2_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Resend API (for international emails)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@yourdomain.com
RESEND_FROM_NAME=Your Name
